# DEQOIN APPOINTMENT SYSTEM CONFIGURATION
# ----------------------------------------
# 1. Google Workspace hesabınızdan bir "Uygulama Şifresi" (App Password) oluşturun.
# 2. Aşağıdaki değişkenleri .env veya .env.local dosyanıza ekleyin.

# Gmail Workspace Hesabı
GMAIL_USER=randevu@deqoin.com

# Google Uygulama Şifresi (Sıradan şifreniz DEĞİL, 16 haneli özel kod)
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Site URL (metadataBase ve mutlak linkler için)
NEXT_PUBLIC_SITE_URL=https://deqoin.com

# Opsiyonel: Diğer SMTP Sunucusu kullanıyorsanız
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
